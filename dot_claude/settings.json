{
  "model": "opus",
  "outputStyle": "Token Efficiency",
  "cleanupPeriodDays": 30,

  "env": {
    "CLAUDE_LANGUAGE": "ja",
    "SHELL": "/opt/homebrew/bin/zsh",
    "BASH_DEFAULT_TIMEOUT_MS": "600000",
    "BASH_MAX_TIMEOUT_MS": "600000",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "true",
    "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}",
    "DEVIN_API_KEY": "${DEVIN_API_KEY}"
  },

  "permissions": {
    "allow": [
      "Bash",
      "Edit(**)",
      "Glob(**)",
      "GlobTool(**)",
      "Grep(**)",
      "GrepTool(**)",
      "LS(**)",
      "MultiEdit(**)",
      "Read(**)",
      "TodoRead",
      "TodoWrite(**)",
      "WebFetch(domain:*)",
      "WebSearch",
      "Write(**)"
    ],
    "deny": [
      "Bash(bash:*)",
      "Bash(sh:*)",
      "Bash(sudo:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(format:*)",
      "Bash(> /dev/sda:*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf ../*)",
      "Bash(chmod 777:*)",
      "Bash(chmod -R 777:*)",
      "Bash(chown -R:*)",
      "Bash(apt-get install:*)",
      "Bash(brew install:*)",
      "Bash(bundle install:*)",
      "Bash(gem install:*)",
      "Bash(npm install -g:*)",
      "Bash(pip install:*)",
      "Bash(yum install:*)",
      "Bash(git checkout:*)",
      "Bash(git config:*)",
      "Bash(git rebase:*)",
      "Bash(git clean:*)",
      "Bash(gh api --method DELETE:*)",
      "Bash(gh auth logout:*)",
      "Bash(gh auth refresh:*)",
      "Bash(gh gist create:*)",
      "Bash(gh gist delete:*)",
      "Bash(gh gpg-key add:*)",
      "Bash(gh gpg-key delete:*)",
      "Bash(gh release create:*)",
      "Bash(gh release delete:*)",
      "Bash(gh release upload:*)",
      "Bash(gh repo archive:*)",
      "Bash(gh repo clone:*)",
      "Bash(gh repo create:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh repo deploy-key:*)",
      "Bash(gh repo edit:*)",
      "Bash(gh repo fork:*)",
      "Bash(gh repo rename:*)",
      "Bash(gh repo sync:*)",
      "Bash(gh repo unarchive:*)",
      "Bash(gh secret delete:*)",
      "Bash(gh secret set:*)",
      "Bash(gh ssh-key add:*)",
      "Bash(gh ssh-key delete:*)",
      "Bash(gh workflow disable:*)",
      "Bash(gh workflow enable:*)",
      "Bash(gh workflow run:*)"
    ]
  },

  "attribution": {
    "commit": "",
    "pr": ""
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "~/.claude/scripts/deny-check.sh" },
          { "type": "command", "command": "~/.claude/scripts/check-ai-commit.sh" }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "~/.claude/scripts/preserve-file-permissions.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "~/.claude/scripts/ja-space-format.sh" },
          { "type": "command", "command": "~/.claude/scripts/auto-comment.sh" }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "~/.claude/scripts/preserve-file-permissions.sh" }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "osascript -e 'display notification \"Awaiting confirmation\" with title \"Claude Code\"' && afplay -v 0.3 ~/.claude/assets/confirm.mp3" }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "~/.claude/scripts/code-review-hook.sh" }
        ]
      }
    ]
  },

  "statusLine": {
    "type": "command",
    "command": "~/.claude/scripts/statusline.sh"
  },

  "enabledPlugins": {
    "common@applibot-claude-code-plugins": true,
    "react@applibot-claude-code-plugins": true,
    "unity@applibot-claude-code-plugins": true
  },

  "extraKnownMarketplaces": {
    "applibot-claude-code-plugins": {
      "source": {
        "source": "git",
        "url": "https://github.com/applibot-inc/claude-code-plugins.git"
      }
    }
  }
}
